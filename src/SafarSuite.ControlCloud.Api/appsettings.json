{
  "Persistence": {
    "Provider": "File"
  },
  "ConnectionStrings": {
    "ControlCloud": ""
  },
  "ControlCloud": {
    "EntitlementSigning": {
      "Issuer": "SafarSuite.ControlCloud",
      "Audience": "SafarSuite.ClientPortal",
      "ActiveKeyId": "local-entitlement-dev",
      "SigningKeys": [
        {
          "KeyId": "local-entitlement-dev",
          "Secret": "local-entitlement-signing-secret-change-before-cloud"
        }
      ]
    },
    "Receiver": {
      "ReceiptStorePath": "App_Data/control-cloud-receipts.jsonl",
      "ProjectionStorePath": "App_Data/control-cloud-client-projections.json",
      "SigningKeys": [
        {
          "KeyId": "local-dev",
          "Secret": "local-development-signing-secret-change-before-cloud"
        }
      ]
    },
    "CommandQueue": {
      "CommandStorePath": "App_Data/control-cloud-installation-commands.json",
      "AcknowledgementStorePath": "App_Data/control-cloud-installation-command-acknowledgements.json"
    },
    "SetupTokens": {
      "TokenBytes": 32,
      "TokenStorePath": "App_Data/control-cloud-installation-setup-tokens.json"
    },
    "BootstrapPackages": {
      "CloudBaseUrl": "http://localhost:5127",
      "InstallScriptUrl": ""
    },
    "Diagnostics": {
      "DiagnosticStorePath": "App_Data/control-cloud-installation-diagnostics.json"
    }
  },
  "ClientPortal": {
    "ProviderAccess": {
      "SharedSecret": "local-development-provider-access-secret-change-before-cloud"
    },
    "Access": {
      "SessionSigningSecret": "local-development-client-portal-session-secret-change-before-cloud",
      "SessionMinutes": 60,
      "InvitationTokenBytes": 32,
      "IdentityStorePath": "App_Data/client-portal-identities.json"
    },
    "InvitationDelivery": {
      "Provider": "File",
      "StorePath": "App_Data/client-portal-invitation-deliveries.jsonl",
      "FromEmail": "no-reply@safarsuite.local",
      "FromName": "SafarSuite Control Cloud",
      "SubjectPrefix": "SafarSuite",
      "SmtpHost": "",
      "SmtpPort": 587,
      "EnableSsl": true,
      "Username": "",
      "Password": ""
    },
    "Audit": {
      "Enabled": true,
      "StorePath": "App_Data/client-portal-audit-events.jsonl"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
