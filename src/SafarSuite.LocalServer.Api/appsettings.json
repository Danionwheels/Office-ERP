{
  "LocalServer": {
    "ControlCloud": {
      "BaseUrl": "http://localhost:5127"
    },
    "BootstrapTrust": {
      "ConfigurationStorePath": "App_Data/local-server-bootstrap-configuration.json",
      "SigningKeys": [
        {
          "KeyId": "local-entitlement-dev",
          "Secret": "local-entitlement-signing-secret-change-before-cloud"
        }
      ]
    },
    "EntitlementTrust": {
      "ExpectedIssuer": "SafarSuite.ControlCloud",
      "ExpectedAudience": "SafarSuite.ClientPortal",
      "CacheStorePath": "App_Data/local-server-entitlement-cache.json",
      "TrustStateStorePath": "App_Data/local-server-entitlement-trust-state.json",
      "ImportAuditStorePath": "App_Data/local-server-entitlement-import-audit.json",
      "SigningKeys": [
        {
          "KeyId": "local-entitlement-dev",
          "Secret": "local-entitlement-signing-secret-change-before-cloud"
        }
      ]
    },
    "Commands": {
      "AppActivationRevocationStorePath": "App_Data/local-server-app-activation-revocations.json"
    },
    "Runtime": {
      "EnableBackgroundWorker": false,
      "EnableEntitlementPull": true,
      "EnableHeartbeat": true,
      "EnableCommandPolling": true,
      "EntitlementPullIntervalSeconds": 900,
      "HeartbeatIntervalSeconds": 300,
      "CommandPollIntervalSeconds": 120
    },
    "Pairing": {
      "DisplayName": "",
      "HttpsUrl": "",
      "PairingMode": "ManagerApproval",
      "TlsCertificateSha256": "",
      "TlsCaSha256": "",
      "ServerPairingPublicKey": "",
      "ServerPairingKeySha256": "",
      "DeviceStorePath": "App_Data/local-server-device-pairings.json",
      "RequestExpiresInHours": 24
    },
    "PairingAbuseControls": {
      "Enabled": true,
      "AnonymousRequestBodyLimitBytes": 16384,
      "AnonymousConcurrentRequestsPerRemote": 4,
      "DiscoveryRequestsPerRemotePerMinute": 120,
      "HelloRequestsPerRemotePerMinute": 60,
      "PairingRequestsPerRemotePerHour": 12,
      "PairingRequestsPerDeviceInstallIdPerDay": 4,
      "PairingRequestsPerFingerprintPerDay": 4,
      "PairingStatusPollsPerRequestPerMinute": 30,
      "CredentialFailuresPerDevicePer15Minutes": 10,
      "LoginFailuresPerActorPer15Minutes": 10,
      "PendingQueueMaxRecords": 100,
      "PendingRequestTtlHours": 48,
      "DuplicateCoalescingWindowHours": 24,
      "TemporaryQuarantineMinutes": 30,
      "ManualDenyTtlHours": 24,
      "SecurityEventReadLimit": 100,
      "SecurityEventRetentionDays": 30,
      "SecurityEventMaxRecords": 5000,
      "SecurityEventStorePath": "App_Data/local-server-pairing-security-events.json"
    },
    "ManagerSessions": {
      "SigningKeyId": "local-manager-session-dev",
      "SigningSecret": "local-manager-session-secret-change-before-production",
      "SessionMinutes": 60
    }
  },
  "DeviceCredentials": {
    "SigningKeyId": "safarsuite-app-device-local",
    "SigningSecret": "local-device-credential-signing-secret-change-before-cloud",
    "ExpiresInDays": 3650
  },
  "UserSessions": {
    "SigningKeyId": "safarsuite-app-session-local",
    "SigningSecret": "local-manager-session-signing-secret-change-before-cloud"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
