# Disposable Integration Lab only. CONTROL_DESK_HOST is not a production Control Desk requirement.
CONTROL_CLOUD_HOST=cloud-staging.forgeaxis.tech
CONTROL_DESK_HOST=desk-staging.forgeaxis.tech

CONTROL_CLOUD_DB_NAME=safarsuite_control_cloud_staging
CONTROL_CLOUD_DB_USER=safarsuite_cloud
CONTROL_CLOUD_DB_PASSWORD=replace-with-long-random-password
CONTROL_CLOUD_DB_HOST_PORT=55432

CONTROL_DESK_DB_NAME=safarsuite_control_desk_staging
CONTROL_DESK_DB_USER=safarsuite_desk
CONTROL_DESK_DB_PASSWORD=replace-with-long-random-password
CONTROL_DESK_DB_HOST_PORT=55433
CONTROL_DESK_SESSION_SIGNING_SECRET=replace-with-independent-long-random-session-secret

CONTROL_DESK_PUBLISHER_SIGNING_KEY_ID=staging-control-desk-202607
CONTROL_DESK_PUBLISHER_SIGNING_SECRET=must-match-secrets-control-desk-publisher-hmac

CONTROL_CLOUD_ENTITLEMENT_SIGNING_KEY_ID=staging-entitlement-202607
CONTROL_CLOUD_APP_ACTIVATION_SIGNING_KEY_ID=staging-app-activation-p256-202607

PROVIDER_ACCESS_SHARED_SECRET=must-match-secrets-provider-access-shared-secret
# Both Client Portal secrets are required outside Development, must differ, and
# must be replaced with independently generated values of at least 32 bytes.
CLIENT_PORTAL_SESSION_SIGNING_SECRET=replace-with-long-random-session-secret
CLIENT_PORTAL_MFA_PROTECTION_SECRET=replace-with-long-random-mfa-protection-secret
CLIENT_PORTAL_PUBLIC_URL=https://cloud-staging.forgeaxis.tech/client-portal/index.html

# SMTP is mandatory outside Development. SMTP_USER and SMTP_PASS must either
# both be set or both remain empty for an anonymous relay.
CLIENT_PORTAL_INVITATION_DELIVERY_PROVIDER=Smtp
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_ADDRESS=no-reply@forgeaxis.tech
